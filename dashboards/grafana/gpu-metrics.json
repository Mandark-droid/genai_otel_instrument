{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for GPU metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "description": "GPU monitoring dashboard for TraceVerde (genai-otel-instrument)",
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "GPU Utilization",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "title": "GPU Utilization",
      "type": "gauge",
      "targets": [
        {
          "expr": "gen_ai_gpu_utilization",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "title": "Memory Utilization",
      "type": "gauge",
      "targets": [
        {
          "expr": "gen_ai_gpu_memory_utilization",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "title": "Temperature",
      "type": "gauge",
      "targets": [
        {
          "expr": "gen_ai_gpu_temperature",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "title": "Power Draw",
      "type": "stat",
      "targets": [
        {
          "expr": "gen_ai_gpu_power",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 6,
      "title": "Time Series",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "max": 100,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 7,
      "title": "GPU Utilization Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gen_ai_gpu_utilization",
          "legendFormat": "GPU {{gpu_index}} Compute"
        },
        {
          "expr": "gen_ai_gpu_memory_utilization",
          "legendFormat": "GPU {{gpu_index}} Memory"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "decmbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 8,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gen_ai_gpu_memory_used",
          "legendFormat": "GPU {{gpu_index}} Used"
        },
        {
          "expr": "gen_ai_gpu_memory_total",
          "legendFormat": "GPU {{gpu_index}} Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 9,
      "title": "Temperature Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gen_ai_gpu_temperature",
          "legendFormat": "GPU {{gpu_index}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 10,
      "title": "Power Consumption Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gen_ai_gpu_power",
          "legendFormat": "GPU {{gpu_index}} Draw"
        },
        {
          "expr": "gen_ai_gpu_power_limit",
          "legendFormat": "GPU {{gpu_index}} Limit"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 11,
      "title": "Aggregate (Multi-GPU)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "id": 12,
      "title": "Mean Utilization",
      "type": "stat",
      "targets": [
        { "expr": "gen_ai_gpu_aggregate_mean_utilization", "legendFormat": "Mean" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "decgbytes" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "id": 13,
      "title": "Total Memory Used",
      "type": "stat",
      "targets": [
        { "expr": "gen_ai_gpu_aggregate_total_memory_used", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "watt" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 25 },
      "id": 14,
      "title": "Total Power",
      "type": "stat",
      "targets": [
        { "expr": "gen_ai_gpu_aggregate_total_power", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 25 },
      "id": 15,
      "title": "Max Temperature",
      "type": "stat",
      "targets": [
        { "expr": "gen_ai_gpu_aggregate_max_temperature", "legendFormat": "Max" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpu", "genai", "traceverde", "nvidia", "amd"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "TraceVerde - GPU Metrics",
  "uid": "traceverde-gpu-metrics",
  "version": 1
}
