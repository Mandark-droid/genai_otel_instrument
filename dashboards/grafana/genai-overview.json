{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for GenAI metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "GenAI/LLM observability dashboard for TraceVerde (genai-otel-instrument)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "TraceVerde Docs",
      "type": "link",
      "url": "https://github.com/Mandark-droid/genai_otel_instrument"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "title": "Request Rate by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_requests_total[$__rate_interval])) by (gen_ai_system)",
          "legendFormat": "{{gen_ai_system}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "title": "Token Usage (Prompt vs Completion)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"prompt\"}[$__rate_interval]))",
          "legendFormat": "Prompt Tokens"
        },
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"completion\"}[$__rate_interval]))",
          "legendFormat": "Completion Tokens"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "title": "Cost Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(gen_ai_cost_total[$__rate_interval])) by (gen_ai_system)",
          "legendFormat": "{{gen_ai_system}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 50
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "title": "Latency Distribution",
      "type": "histogram",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_operation_duration_bucket[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_errors_total[$__rate_interval])) by (gen_ai_system, error_type)",
          "legendFormat": "{{gen_ai_system}} - {{error_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "title": "Top Models by Usage",
      "type": "table",
      "targets": [
        {
          "expr": "topk(10, sum(gen_ai_requests_total) by (gen_ai_request_model))",
          "legendFormat": "{{gen_ai_request_model}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "gen_ai_request_model": "Model",
              "Value": "Total Requests"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 8,
      "title": "Cost Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 },
      "id": 9,
      "title": "Total Cost (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(gen_ai_cost_total[24h]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 26 },
      "id": 10,
      "title": "Total Requests (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(gen_ai_requests_total[24h]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 26 },
      "id": 11,
      "title": "Total Tokens (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(gen_ai_client_token_usage_total[24h]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 26 },
      "id": 12,
      "title": "Avg Latency (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_operation_duration_sum[24h])) / sum(rate(gen_ai_client_operation_duration_count[24h]))",
          "legendFormat": "Avg"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["genai", "llm", "traceverde", "opentelemetry"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TraceVerde - GenAI Overview",
  "uid": "traceverde-genai-overview",
  "version": 1
}
